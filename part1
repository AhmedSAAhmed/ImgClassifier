        <span class="n">new_height</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">height</span><span class="o">*</span><span class="mi">256</span><span class="o">/</span><span class="n">width</span><span class="p">)</span>
    <span class="k">else</span><span class="p">:</span>
        <span class="n">new_height</span> <span class="o">=</span> <span class="mi">256</span>
        <span class="n">new_width</span> <span class="o">=</span> <span class="nb">int</span><span class="p">(</span><span class="n">width</span><span class="o">*</span><span class="mi">256</span><span class="o">/</span><span class="n">height</span><span class="p">)</span>
        
        
    <span class="n">pil_image</span> <span class="o">=</span> <span class="n">pil_image</span><span class="o">.</span><span class="n">resize</span><span class="p">((</span><span class="n">new_width</span><span class="p">,</span><span class="n">new_height</span><span class="p">))</span>
    
    <span class="n">left</span> <span class="o">=</span> <span class="p">(</span><span class="n">new_width</span><span class="o">-</span><span class="mi">224</span><span class="p">)</span><span class="o">/</span><span class="mi">2</span>
    <span class="n">top</span> <span class="o">=</span> <span class="p">(</span><span class="n">new_height</span><span class="o">-</span><span class="mi">224</span><span class="p">)</span><span class="o">/</span><span class="mi">2</span>
    <span class="n">right</span> <span class="o">=</span> <span class="n">left</span> <span class="o">+</span><span class="mi">224</span>
    <span class="n">bottom</span> <span class="o">=</span> <span class="n">top</span> <span class="o">+</span> <span class="mi">224</span>
    <span class="n">pil_image</span> <span class="o">=</span> <span class="n">pil_image</span><span class="o">.</span><span class="n">crop</span><span class="p">((</span><span class="n">new_width</span><span class="p">,</span><span class="n">new_height</span><span class="p">))</span>
    
